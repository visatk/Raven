{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "net",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-29",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
    "d1_databases": [
    {
      "binding": "DB",
      "database_name": "netbot",
      "database_id": "280a608f-b079-4bc4-b1b3-0f2dea8c7e75"
    }
  ],
   "kv_namespaces": [
    {
      "binding": "KV",
      "id": "1e5b75dbf4084655b523878f92da0b00"
    }
  ]
}
